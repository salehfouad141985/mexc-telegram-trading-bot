# ===================================
# Shaabane Signals Bot - Configuration
# ===================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx

# --- MEXC API ---
MEXC_API_KEY=your_mexc_api_key_here
MEXC_SECRET_KEY=your_mexc_secret_key_here

# --- Trading Settings ---
TRADE_AMOUNT_USDT=10
MIN_SCORE=7
AUTO_TRADE=true
DRY_RUN=true

# --- Risk Management ---
# Percentage of trade amount to allocate to each target
TP1_PERCENT=30
TP2_PERCENT=30
TP3_PERCENT=25
TP4_PERCENT=15

# --- Dashboard ---
DASHBOARD_PORT=3000
